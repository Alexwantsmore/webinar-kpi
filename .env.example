# Skopiuj ten plik do .env i wypełnij wartości.
# .env jest w .gitignore — wartości NIE trafią do repo.
# W produkcji (Vercel) wpisz te zmienne w: Project → Settings → Environment Variables

# --- Meta Ads API ---
# Token z https://developers.facebook.com/tools/explorer (uprawnienia: ads_read, read_insights)
META_TOKEN=

# --- WebinarJam API ---
# Klucz z: panel WebinarJam → profil → Advanced Integration → API Key
WJ_API_KEY=

# --- FTP (transfer raportów / backupów) ---
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=
FTP_REMOTE_DIR=/
